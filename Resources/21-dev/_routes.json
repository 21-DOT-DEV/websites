{
  "version": 1,
  "description": "Route config for 21.dev — only invoke middleware for HTML pages",
  "include": ["/*"],
  "exclude": [
    "/svg/*",
    "/static/*",
    "/.well-known/*",
    "/favicon.ico",
    "/robots.txt",
    "/sitemap.xml",
    "/sitemap_index.xml",
    "/*.css",
    "/*.js",
    "/*.png",
    "/*.jpg",
    "/*.svg",
    "/*.woff2",
    "/*.woff",
    "/*.ico"
  ]
}