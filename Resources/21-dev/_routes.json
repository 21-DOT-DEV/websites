{
  "version": 1,
  "description": "Route config for 21.dev — only invoke middleware for HTML pages",
  "include": ["/*"],
  "exclude": [
    "/*.avif",
    "/*.css",
    "/*.gif",
    "/*.ico",
    "/*.jpeg",
    "/*.jpg",
    "/*.js",
    "/*.json",
    "/*.map",
    "/*.md",
    "/*.png",
    "/*.svg",
    "/*.txt",
    "/*.wasm",
    "/*.webp",
    "/*.woff",
    "/*.woff2",
    "/*.xml"
  ]
}