# Cloudflare Pages Headers Configuration — 21.dev (Production)
# https://developers.cloudflare.com/pages/platform/headers/

# Specific patterns must appear before the catch-all `/*` rules because Cloudflare applies the first match. Add new patterns above the HTML fallback sections below.

# Static assets — daily caching until filenames are hashed
/static/*
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/assets/*
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

# Serve plain text files with correct content-type
# Using explicit paths instead of /*.txt glob to avoid Content-Type mismatch on 404 pages
/llms.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

/robots.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

# No-store endpoints (well-known configs)
/.well-known/*
  Cache-Control: no-store
  Pragma: no-cache

# cfpages-ignore: glob-content-type (blog posts grow over time; explicit paths impractical)
/data/blog/*.md
  Content-Type: text/markdown; charset=utf-8
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex
  Cache-Control: public, max-age=300, must-revalidate
  Vary: Accept-Encoding

# Favicon and PWA assets — daily caching (cache-busted via ?v= in HTML link tags)
/favicon.ico
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/favicon-96x96.png
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/apple-touch-icon.png
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/site.webmanifest
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/web-app-manifest-192x192.png
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/web-app-manifest-512x512.png
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

# Production HTML pages — include strict security headers + HSTS
# NOTE: Extend CSP allowlists by appending origins to the existing directive (e.g., add another `connect-src` host) rather than removing defaults.
/*
  Link: </llms.txt>; rel="llms-txt"
  X-Llms-Txt: /llms.txt
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://static.cloudflareinsights.com; font-src 'self'; img-src 'self' data:; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), fullscreen=(self)
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cache-Control: public, max-age=300, must-revalidate
  Vary: Accept-Encoding
