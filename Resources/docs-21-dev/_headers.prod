# Cloudflare Pages Headers — docs.21.dev (Production)
# Production builds serve static DocC content with full security headers including HSTS.

# Cloudflare Pages applies ALL matching rules and CONCATENATES values for repeated header keys (e.g. two rules each setting Cache-Control yields a single comma-separated value). To avoid that, the catch-all `/*` rule below intentionally does NOT set Cache-Control or Vary; specific paths declare their own caching. Without this, the immutable hashed assets under /css/* /js/* /img/* would be clamped to the catch-all's max-age=300 instead of caching for 1 year.

# JavaScript bundle (DocC search) — content-hashed filenames, safe to mark immutable
/js/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# CSS stylesheets (DocC theme) — content-hashed filenames, safe to mark immutable
/css/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# DocC renderer UI icons — webpack content-hashed, safe to mark immutable
/img/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# Author-provided assets (@Image, @Video, @Download) — filenames not hashed, daily TTL
/images/*
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/videos/*
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/downloads/*
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

# /.well-known/* — short TTL with stale-while-revalidate
/.well-known/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# DocC data directory (symbol JSON)
/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# Ensure DocC markdown assets are served as text/markdown (CF Pages does not
# auto-map .md to text/markdown by default; explicit rule prevents regression).
/data/documentation/**/*.md
  Content-Type: text/markdown; charset=utf-8

# JSON data (DocC linkable-entities, metadata, symbol JSON)
/**/*.json
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# Serve plain text files with correct content-type
# Using explicit paths instead of /*.txt glob to avoid Content-Type mismatch on 404 pages
/llms.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding

/robots.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding

# Content negotiation: markdown alternate for AI agents
/documentation/*
  Vary: Accept

# Production HTML (DocC) — strict baseline + CSP allowing DocC assets and analytics
# NOTE: Extend CSP allowlists by appending origins (e.g., extra script host) instead of removing defaults to keep minimum protections intact.
# Cache-Control is intentionally OMITTED here — see top-of-file note. HTML pages
# rely on Cloudflare’s default heuristic caching plus the per-page ETag emitted
# by Resources/docs-21-dev/functions/_middleware.ts; conditional GETs return 304.
# Link relations and X-Llms-Txt are emitted by _handlers/html.ts (HTML responses
# only) — see that file's JSDoc for rationale.
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://static.cloudflareinsights.com; font-src 'self' data:; img-src 'self' data:; script-src 'self' https://static.cloudflareinsights.com 'sha256-Tmnua9Q+ofeiLwDiFowbjAxSJRmhO2KE+f0QIsqwNfw='; style-src 'self' 'unsafe-inline'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), fullscreen=(self)
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
