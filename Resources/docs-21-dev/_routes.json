{
  "version": 1,
  "description": "Route config for docs.21.dev — only invoke middleware for HTML pages",
  "include": ["/*"],
  "exclude": [
    "/js/*",
    "/css/*",
    "/data/*",
    "/index/*",
    "/favicon.ico",
    "/robots.txt",
    "/llms.txt",
    "/llms-full.txt",
    "/sitemap.xml",
    "/*.md",
    "/*.css",
    "/*.js",
    "/*.png",
    "/*.jpg",
    "/*.svg",
    "/*.woff2",
    "/*.woff",
    "/*.ico",
    "/*.json"
  ]
}