# Cloudflare Pages Headers — docs.21.dev (Preview/Development)
# Preview builds serve static DocC content without HSTS for safety.

# Cloudflare Pages matches top-to-bottom; keep specific asset/JSON patterns above the catch-all HTML sections below.

# JavaScript bundle (DocC search) — content-hashed filenames, safe to mark immutable
/js/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# CSS stylesheets (DocC theme) — content-hashed filenames, safe to mark immutable
/css/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# DocC renderer UI icons — webpack content-hashed, safe to mark immutable
/img/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# Author-provided assets (@Image, @Video, @Download) — filenames not hashed, daily TTL
/images/*
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/videos/*
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

/downloads/*
  Cache-Control: public, max-age=86400
  Vary: Accept-Encoding

# No-store zones (well-known + JSON)
/.well-known/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# DocC data directory (symbol JSON)
/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# Catch-all JSON (linkable-entities, etc.)
/**/*.json
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
  Vary: Accept-Encoding
  X-Robots-Tag: noindex

# Serve plain text files with correct content-type
# Using explicit paths instead of /*.txt glob to avoid Content-Type mismatch on 404 pages
/llms.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

/robots.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex

# Content negotiation: markdown alternate for AI agents
/documentation/*
  Vary: Accept

# Preview HTML (DocC) — security headers without HSTS, noindex to prevent search indexing
# NOTE: Extend CSP allowlists by appending origins (e.g., extra script host) instead of removing defaults to keep minimum protections intact.
/*
  Link: </llms.txt>; rel="llms-txt"
  Link: </llms-full.txt>; rel="llms-full-txt"
  Link: </sitemap.xml>; rel="sitemap"
  # X-Llms-Txt: companion to Link rel="llms-txt" for non-RFC-8288 tooling (Mintlify pattern).
  X-Llms-Txt: /llms.txt
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://static.cloudflareinsights.com; font-src 'self' data:; img-src 'self' data:; script-src 'self' https://static.cloudflareinsights.com 'sha256-Tmnua9Q+ofeiLwDiFowbjAxSJRmhO2KE+f0QIsqwNfw='; style-src 'self' 'unsafe-inline'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), fullscreen=(self)
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-Robots-Tag: noindex, nofollow

# cfpages-ignore: glob-content-type (DocC generates hundreds of .md files; explicit paths impractical)
# Detach Link and X-Llms-Txt set by the catch-all `/*` rule above: those headers
# describe HTML pages (llms-txt index, sitemap) and should not appear on raw
# markdown asset responses. Cloudflare Pages `! HeaderName` syntax removes a
# header set by an EARLIER matching rule, so this block must come after `/*`.
/data/documentation/**/*.md
  Content-Type: text/markdown; charset=utf-8
  ! Link
  ! X-Llms-Txt
